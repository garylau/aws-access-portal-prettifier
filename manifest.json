{
  "manifest_version": 3,
  "name": "AWS Access Portal Prettifier",
  "version": "1.1",
  "description": "Prettifies the AWS access portal with orange card styling",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.awsapps.com/*",
        "https://*.awsapps.cn/*"
      ],
      "css": ["src/styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.awsapps.com/*",
        "https://*.awsapps.cn/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": []
}
